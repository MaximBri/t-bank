{
  "name": "t-bank-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:short": "vitest run --coverage --coverage.reporter=text-summary",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:playwright:open": "playwright show-report ./.artifacts/e2e/playwright-report",
    "test:e2e:allure:generate": "allure generate .artifacts/e2e/allure-results --output .artifacts/e2e/allure-report/awesome",
    "test:e2e:allure:open": "allure generate .artifacts/e2e/allure-results --output .artifacts/e2e/allure-report/awesome --open",
    "test:e2e:allure:clean": "rm -rf .artifacts/e2e/allure-results .artifacts/e2e/allure-report",
    "test:e2e:allure": "npm run test:e2e; npm run test:e2e:allure:generate",
    "test:e2e:allure:run": "npm run test:e2e:allure:clean; npm run test:e2e; npm run test:e2e:allure:open",
    "test:api": "playwright test -c playwright.api.config.ts",
    "test:api:allure:generate": "allure generate .artifacts/api/allure-results --output .artifacts/api/allure-report/awesome",
    "test:api:allure:open": "allure generate .artifacts/api/allure-results --output .artifacts/api/allure-report/awesome --open",
    "test:api:allure:clean": "rm -rf .artifacts/api/allure-results .artifacts/api/allure-report",
    "test:api:allure": "npm run test:api; npm run test:api:allure:generate",
    "test:api:allure:run": "npm run test:api:allure:clean; npm run test:api; npm run test:api:allure:open"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@tanstack/react-query": "^5.74.11",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.55.0",
    "react-qr-code": "^2.0.18",
    "react-responsive": "^10.0.1",
    "react-router-dom": "^7.14.2",
    "sonner": "^2.0.7",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "allure": "^3.8.1",
    "allure-playwright": "^3.8.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.28.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5"
  }
}
