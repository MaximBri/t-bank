# Docker image settings (needed only if pulling images from GHCR instead of building locally)
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=maximbri/t-bank
IMAGE_TAG=latest
GHCR_USERNAME=your_github_username
GHCR_TOKEN=your_github_personal_access_token

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/tbank
SPRING_DATASOURCE_USERNAME=tbank
SPRING_DATASOURCE_PASSWORD=tbank
POSTGRES_DB=tbank
POSTGRES_USER=tbank
POSTGRES_PASSWORD=tbank

# Redis
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# Ports
FRONTEND_PORT=3001
BACKEND_PORT=8080

# Auth
JWT_SECRET=change_me_to_any_random_string
# Set to false for local HTTP development, true only in production (HTTPS)
JWT_COOKIE_SECURE=false

# S3 / MinIO (prod)
# Учётные данные MinIO — задайте надёжные значения, НЕ minioadmin
MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me_to_a_strong_secret
# Публичный адрес хранилища, по которому браузер открывает presigned-ссылки.
# ВАЖНО: должен быть отдельным хостом БЕЗ префикса пути (напр. сабдомен
# s3.<домен>), проксируемым в MinIO 1:1. Префикс пути (вида /s3-storage)
# ломает SigV4-подпись presigned-URL → SignatureDoesNotMatch. См. DEPLOY.md.
# Пример: https://s3.your-domain.tld
SPRING_CLOUD_AWS_S3_ENDPOINT=https://s3.your-domain.tld
SPRING_CLOUD_AWS_S3_BUCKET_NAME=tbank-receipts
SPRING_CLOUD_AWS_REGION_STATIC=us-east-1
