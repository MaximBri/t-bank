        "operationId": "me",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUserResponse"
                }
              }
            }
          }
        }
      }
    },
    "/events/{eventId}/participants/{userId}": {
      "delete": {
        "tags": [
          "Participants"
        ],
        "summary": "Удалить участника или отозвать приглашение",
        "description": "Удаление участника из события или отзыв приглашения (только для владельца)",
        "operationId": "removeParticipant",
        "parameters": [
          {
            "name": "eventId",
            "in": "path",
            "description": "ID события",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "userId",
            "in": "path",
            "description": "ID пользователя",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Участник удален / приглашение отозвано"
          },
          "403": {
            "description": "Недостаточно прав"
          },
          "404": {
            "description": "Участник не найден"
          }
        }
      }
    },
    "/events/{eventId}/categories/{categoryId}": {
      "delete": {
        "tags": [
          "category-controller"
        ],
        "operationId": "deleteCategory",
        "parameters": [
          {
            "name": "eventId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "categoryId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
