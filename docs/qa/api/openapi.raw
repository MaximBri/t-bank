  "paths": {
    "/user/invitations/{invitationId}/resolve": {
      "post": {
        "tags": [
          "Participants"
        ],
        "summary": "Принять или отклонить приглашение",
        "description": "Ответ на приглашение от владельца группы",
        "operationId": "resolveInvitation",
        "parameters": [
          {
            "name": "invitationId",
            "in": "path",
            "description": "ID приглашения",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResolveInvitationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Решение принято"
          },
          "403": {
            "description": "Недостаточно прав"
          },
          "404": {
            "description": "Приглашение не найдено"
          },
          "410": {
            "description": "Приглашение просрочено"
          }
        }
      }
    },
    "/groups/join": {
      "post": {
        "tags": [
          "Participants"
        ],
        "summary": "Подать заявку на вступление в группу",
        "description": "Пользователь может подать заявку на вступление в группу по инвайт-коду. Заявка требует подтверждения от владельца группы.",
        "operationId": "joinGroup",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinGroupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Заявка принята и ожидает рассмотрения владельцем"
          },
          "404": {
            "description": "Инвайт-код не найден"
          },
          "409": {
            "description": "Вы уже подали заявку в эту группу"
          },
          "410": {
            "description": "Ссылка просрочена (прошло \u003E 48 часов)"
          }
        }
      }
    },
